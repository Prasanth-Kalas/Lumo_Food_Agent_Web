# Anthropic Claude — required for the agent.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The Claude model to use. Sonnet is the right default for tool-use heavy flows.
ANTHROPIC_MODEL=claude-sonnet-4-6

# US metros Lumo serves. Comma-separated list of slugs from METROS in
# lib/types.ts (austin, los_angeles, san_francisco, chicago). Leave unset to
# enable all four. Used to scope search results and in the system prompt.
# SERVICE_METROS=austin,los_angeles,san_francisco,chicago

# Deepgram — required for STT (Sprint D voice upgrade).
# https://console.deepgram.com/project/<you>/api-keys
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI — required for TTS (gpt-4o-mini-tts).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Once you get MealMe keys, add them here and flip the flag in lib/config.ts
# MEALME_API_KEY=
# MEALME_BASE_URL=https://api.mealme.ai

# Stripe — required for checkout (Sprint C and beyond).
# The app falls back to a cash-on-delivery demo flow if these are unset,
# so local dev still works without a Stripe account.
# Test-mode keys only; production keys come from Vercel env, never committed.
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ─── Lumo Super Agent wiring (no env vars needed here today) ────────────────
# The Super Agent discovers this project by calling /.well-known/agent.json on
# this deploy's public URL. That discovery is driven by the shell's env
# (LUMO_FOOD_AGENT_URL), not this repo's env. This food agent pre-dates the
# SDK manifest contract (#33 adds conformance) — until that lands, the Super
# Agent proxies /api/chat directly; no manifest/OpenAPI is served here yet.
